# === BASE DE DATOS ===
DATABASE_URL="postgresql://watchparty_user:TU_PASSWORD_SEGURA@localhost:5432/watchparty"

# === NEXTAUTH ===
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-aqui"
# URL de tu servidor (con dominio o IP)
NEXTAUTH_URL="http://localhost:3000"

# === ALMACENAMIENTO ===
# Opciones: "local" o "s3"
STORAGE_MODE=local
# Ruta para almacenamiento local
UPLOAD_DIR=/opt/watchparty/uploads

# === AWS S3 (solo si STORAGE_MODE=s3) ===
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=
# AWS_FOLDER_PREFIX=
# Para MinIO u otro S3-compatible:
# AWS_ENDPOINT_URL=http://localhost:9000
