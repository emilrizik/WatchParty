# === BASE DE DATOS ===
DATABASE_URL="postgresql://watchparty_user:TU_PASSWORD_SEGURA@localhost:5432/watchparty"

# === NEXTAUTH ===
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-aqui"
# URL pública del VPS donde corre la app
NEXTAUTH_URL="https://watchparty.tudominio.com"

# Código único del panel admin
ADMIN_CODE="cambia-este-codigo"

# === ALMACENAMIENTO ===
# Opciones: "local" o "s3"
STORAGE_MODE=s3
# Ruta para almacenamiento local
UPLOAD_DIR=/opt/watchparty/uploads

# === AWS S3 (solo si STORAGE_MODE=s3) ===
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=tu_bucket
# AWS_FOLDER_PREFIX=
# Endpoint S3 o compatible (ej. Abacus / MinIO / R2)
# AWS_ENDPOINT_URL=https://rizik.abacusai.app
# URL pública base para reproducir multimedia desde otro dominio
# AWS_PUBLIC_BASE_URL=https://rizik.abacusai.app

# === ABACUS AI ===
# Necesario para la optimización remota en /api/convert-hls
# ABACUSAI_API_KEY=tu_token
